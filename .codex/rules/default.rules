# Union Square Codex execpolicy.
#
# This file is Starlark, not YAML. Codex loads `.rules` files from
# `.codex/rules/` at startup and validates each rule's examples.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard resets can discard user work. Inspect `git status` and ask before any destructive reset.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
    not_match = [
        "git reset --soft HEAD~1",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "`git clean` can delete untracked user work. Surface the cleanup need instead.",
    match = [
        "git clean -fd",
        "git clean -xdf",
    ],
    not_match = [
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "rebase"],
    decision = "forbidden",
    justification = "Rebase rewrites history. Only run it when the user explicitly asks for that exact operation.",
    match = [
        "git rebase main",
        "git rebase --interactive HEAD~3",
    ],
    not_match = [
        "git merge main",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", ["main", "master"]],
    decision = "forbidden",
    justification = "Never push directly to main or master. Push an issue branch and open a PR.",
    match = [
        "git push origin main",
        "git push origin master",
    ],
    not_match = [
        "git push origin codex-issue-123",
        "git push origin HEAD:refs/heads/codex-issue-123",
    ],
)

# Codex prefix rules do not support wildcard tokens or "contains" checks.
# The pre-tool-use hook enforces arbitrary remote names, force flags in any
# position, and --no-verify in any commit argument order.

prefix_rule(
    pattern = ["git", "push", ["main", "master"]],
    decision = "forbidden",
    justification = "Never push directly to main or master, even when Git infers the remote.",
    match = [
        "git push main",
        "git push master",
    ],
    not_match = [
        "git push codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["git", "push", "upstream", ["main", "master"]],
    decision = "forbidden",
    justification = "Never push directly to main or master on any remote. Use an issue branch and PR.",
    match = [
        "git push upstream main",
        "git push upstream master",
    ],
    not_match = [
        "git push upstream codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["git", "push", ["-u", "--set-upstream"], "origin", ["main", "master"]],
    decision = "forbidden",
    justification = "Never create or update main or master directly. Use an issue branch and PR.",
    match = [
        "git push -u origin main",
        "git push --set-upstream origin master",
    ],
    not_match = [
        "git push -u origin codex-issue-123",
        "git push --set-upstream origin codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", ["HEAD:main", "HEAD:master"]],
    decision = "forbidden",
    justification = "Never push HEAD directly to main or master. Use an issue branch and PR.",
    match = [
        "git push origin HEAD:main",
        "git push origin HEAD:master",
    ],
    not_match = [
        "git push origin HEAD:refs/heads/codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", ["HEAD:refs/heads/main", "HEAD:refs/heads/master"]],
    decision = "forbidden",
    justification = "Never push HEAD directly to refs/heads/main or refs/heads/master. Use an issue branch and PR.",
    match = [
        "git push origin HEAD:refs/heads/main",
        "git push origin HEAD:refs/heads/master",
    ],
    not_match = [
        "git push origin HEAD:refs/heads/codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force pushes can overwrite remote work. Use a normal push or surface the blocker.",
    match = [
        "git push --force origin feature",
    ],
    not_match = [
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Force pushes rewrite remote history. Use a normal push or ask before rewriting history.",
    match = [
        "git push --force-with-lease origin feature",
    ],
    not_match = [
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "RTK must not bypass destructive git protections. Inspect `git status` and ask before any destructive reset.",
    match = [
        "rtk git reset --hard",
        "rtk git reset --hard HEAD~1",
    ],
    not_match = [
        "rtk git reset --soft HEAD~1",
        "rtk git status --short",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "clean"],
    decision = "forbidden",
    justification = "RTK must not bypass destructive git protections. Surface the cleanup need instead.",
    match = [
        "rtk git clean -fd",
        "rtk git clean -xdf",
    ],
    not_match = [
        "rtk git status --short",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "rebase"],
    decision = "forbidden",
    justification = "RTK must not bypass history-rewriting protections. Only rebase when the user explicitly asks for that exact operation.",
    match = [
        "rtk git rebase main",
        "rtk git rebase --interactive HEAD~3",
    ],
    not_match = [
        "rtk git merge main",
        "rtk git status --short",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "commit", "--no-verify"],
    decision = "forbidden",
    justification = "RTK must not bypass commit hooks. Fix the hook failure or surface the blocker.",
    match = [
        "rtk git commit --no-verify -m test",
    ],
    not_match = [
        "rtk git commit -m test",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "push", "origin", ["main", "master"]],
    decision = "forbidden",
    justification = "RTK must not bypass branch protections. Push an issue branch and open a PR.",
    match = [
        "rtk git push origin main",
        "rtk git push origin master",
    ],
    not_match = [
        "rtk git push origin codex-issue-123",
        "rtk git push origin HEAD:refs/heads/codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "push", "origin", ["HEAD:refs/heads/main", "HEAD:refs/heads/master"]],
    decision = "forbidden",
    justification = "RTK must not bypass branch protections. Push an issue branch and open a PR.",
    match = [
        "rtk git push origin HEAD:refs/heads/main",
        "rtk git push origin HEAD:refs/heads/master",
    ],
    not_match = [
        "rtk git push origin HEAD:refs/heads/codex-issue-123",
    ],
)

prefix_rule(
    pattern = ["rtk", "proxy", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "RTK proxy must not bypass destructive git protections. Inspect `git status` and ask before any destructive reset.",
    match = [
        "rtk proxy git reset --hard",
        "rtk proxy git reset --hard HEAD~1",
    ],
    not_match = [
        "rtk proxy git reset --soft HEAD~1",
        "rtk proxy git status --short",
    ],
)

prefix_rule(
    pattern = ["rtk", "proxy", "git", "commit", "--no-verify"],
    decision = "forbidden",
    justification = "RTK proxy must not bypass commit hooks. Fix the hook failure or surface the blocker.",
    match = [
        "rtk proxy git commit --no-verify -m test",
    ],
    not_match = [
        "rtk proxy git commit -m test",
    ],
)

prefix_rule(
    pattern = ["git", "commit", "--no-verify"],
    decision = "forbidden",
    justification = "Never bypass commit hooks. Fix the hook failure or surface the blocker.",
    match = [
        "git commit --no-verify -m test",
    ],
    not_match = [
        "git commit -m test",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "forbidden",
    justification = "Do not merge PRs autonomously. Leave final merge control to a human after review and CI.",
    match = [
        "gh pr merge 210",
        "gh pr merge --auto",
    ],
    not_match = [
        "gh pr view 210",
        "gh pr create --fill",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "create", "--draft"],
    decision = "forbidden",
    justification = "After the issue ledger reaches pr_ready, publish a ready-for-review PR by default. Surface a blocker instead of opening a draft.",
    match = [
        "gh pr create --draft",
        "gh pr create --draft --fill",
    ],
    not_match = [
        "gh pr create --fill",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Refuse broad filesystem deletion.",
    match = [
        "rm -rf /",
    ],
    not_match = [
        "rm -rf target",
    ],
)

prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "`rg` is the preferred read-only code search tool.",
    match = [
        "rg EventCore",
        "rg --files",
    ],
)

prefix_rule(
    pattern = ["ls"],
    decision = "allow",
    justification = "Directory listing is safe for local context gathering.",
    match = [
        "ls",
        "ls .codex",
    ],
)

prefix_rule(
    pattern = ["pwd"],
    decision = "allow",
    justification = "Printing the working directory is safe for local context gathering.",
    match = [
        "pwd",
    ],
)

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show"]],
    decision = "allow",
    justification = "Read-only git inspection is safe for autonomous context gathering.",
    match = [
        "git status --short",
        "git diff -- AGENTS.md",
        "git log --oneline -5",
        "git show HEAD --stat",
    ],
    not_match = [
        "git reset --hard",
        "git push origin main",
    ],
)

prefix_rule(
    pattern = ["rtk", ["ls", "tree", "find", "grep", "rg"]],
    decision = "allow",
    justification = "RTK-wrapped read-only inspection is preferred for high-output local context gathering.",
    match = [
        "rtk ls .codex",
        "rtk rg EventCore",
        "rtk find . -name Cargo.toml",
    ],
    not_match = [
        "rtk git reset --hard",
        "rtk git push origin main",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", ["status", "diff", "log", "show", "branch", "grep", "blame"]],
    decision = "allow",
    justification = "RTK-wrapped read-only git inspection reduces token use during autonomous work.",
    match = [
        "rtk git status --short",
        "rtk git diff -- AGENTS.md",
        "rtk git log --oneline -5",
        "rtk git show HEAD --stat",
    ],
    not_match = [
        "rtk git reset --hard",
        "rtk git push origin main",
    ],
)

prefix_rule(
    pattern = ["gh", "issue"],
    decision = "allow",
    justification = "Union Square tracks implementation work through GitHub issues.",
    match = [
        "gh issue view 210",
        "gh issue edit 210 --body-file /tmp/body.md",
        "gh issue develop 210 --checkout",
    ],
)

prefix_rule(
    pattern = ["gh", "issue-ext"],
    decision = "allow",
    justification = "The migration plan uses GitHub issue relationship metadata managed by gh issue-ext.",
    match = [
        "gh issue-ext show 210",
        "gh issue-ext subissue add 210 211",
        "gh issue-ext blocking add 212 211",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "list", "status", "create", "edit", "comment", "ready", "diff", "checkout"]],
    decision = "allow",
    justification = "PR inspection and ready-for-review create/update operations are needed for autonomous delivery; merging remains forbidden.",
    match = [
        "gh pr view 210",
        "gh pr create --fill",
        "gh pr edit 210 --body-file /tmp/body.md",
        "gh pr checkout 210",
    ],
    not_match = [
        "gh pr merge 210",
    ],
)

prefix_rule(
    pattern = ["just"],
    decision = "allow",
    justification = "`just` is the canonical Union Square command surface and contains project gates.",
    match = [
        "just fmt-check",
        "just fitness",
        "just spec ISSUE=210",
    ],
)

prefix_rule(
    pattern = ["cargo"],
    decision = "allow",
    justification = "Cargo is required for Rust check, test, and dependency workflow.",
    match = [
        "cargo check",
        "cargo test --workspace",
        "cargo add serde",
    ],
)
