{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    "CLAUDE.md",
    "docs/architecture/ARCHITECTURE.md",
    ".opencode/rules/*.md"
  ],
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Default development agent with full tool access",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "rtk *": "allow",
          "gh *": "allow",
          "git *": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git fetch*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "git checkout*": "allow",
          "git merge*": "allow",
          "git remote*": "allow",
          "git rev-parse*": "allow",
          "git reset*": "deny",
          "git clean*": "deny",
          "git rebase*": "deny"
        },
        "task": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Analysis and planning without making changes",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    }
  }
}
